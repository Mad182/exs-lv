<!-- START BLOCK : tasks-intro-text -->
<div class="rs-intro">
    <span class="vc-ghost-item"></span>
    <img id="trollis" class="vc-item" src="{img-server}/bildes/runescape/intro/troll.png" alt="">
    <p class="vc-item" style="max-width:83%"><strong>Achievements</strong>, agrāk zināmi kā <strong>Tasks</strong> vai <strong>Achievement Diaries</strong>, sastāv no izaicinājumu un uzdevumu sērijām, kuras spēlētājam liek veikt spēles personāži, lai pārbaudītu tā zināšanas un iemaņas attiecīgajā teritorijā. 
    <br><span style="position:relative;top:4px">Katras teritorijas uzdevumi tiek iedalīti <strong>4</strong> sarežģītības līmeņos: <strong>vieglie, vidēji grūtie, sarežģītie un ļoti sarežģītie</strong> (<em>elite</em>). Jo tālāk uzdevumu sarakstā spēlētājs tiek, jo grūtāki paliek veicamie uzdevumi, turklāt tie prasa aizvien augstākas prasmes, sarežģītākus kvestus un plašākas zināšanas.</span><br><span style="position:relative;top:8px">Centīgākie spēlētāji nepaliek bez atalgojuma!</span></p>
</div>
<!-- START BLOCK : tasks-intro-text-hidden -->
<div class="simple-note">
  <img style="position:relative;top:3px;margin-right:5px" src="{img-server}/bildes/runescape/ico-tasks.png" alt="">
  Sadaļā esošās pamācības ir ļoti novecojušas un neatbilst situācijai spēlē! Palīdzi atjaunot tās! 
</div>
<!-- END BLOCK : tasks-intro-text-hidden -->
<!-- END BLOCK : tasks-intro-text -->


<!-- START BLOCK : no-tasks-found -->
<p class="simple-note">
    Sadaļai nav pievienotu reģionu.
</p>
<!-- END BLOCK : no-tasks-found -->


<!-- START BLOCK : tasks -->
<div style="margin:20px">

    <h2 style="font-size:20px">Teritorijas</h1>
    <!-- START BLOCK : tasks-has-pages -->
    <div class="guide-block{newline}">
        <p class="guide-title">{series_title}</p>
        <a href="javascript:void(0);">
            <img src="{img-server}/bildes/runescape/tasks/{img}" title="{series_title}" alt="">
        </a>
        <ul>
            <!-- START BLOCK : task -->
            <li><a class="page" href="/read/{strid}">{title}</a></li>
            <!-- END BLOCK : task-->
        </ul>
    </div>
    <!-- END BLOCK : tasks-has-pages -->

    <div class="clearfix"></div>

    <h2 style="font-size:20px">Lapā iztrūkstošās teritorijas</h1>
    <!-- START BLOCK : tasks-no-pages -->
    <div class="guide-block{newline}" style="padding-bottom:5px">
        <p class="guide-title">{series_title}</p>
        <a href="javascript:void(0);">
            <img src="{img-server}/bildes/runescape/tasks/{img}" title="{series_title}" alt="">
        </a>
    </div>
    <!-- END BLOCK : tasks-no-pages -->
    
</div>
<!-- END BLOCK : tasks -->
