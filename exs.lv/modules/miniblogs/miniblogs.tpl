<h1>Jaunākais miniblogos</h1>
<!-- START BLOCK : miniblog-list-->
<p class="core-pager">{pager-next} {pager-numeric} {pager-prev}</p>
<ul id="miniblog-list">
	<!-- START BLOCK : miniblog-list-node-->
	<li><div class="mbox"><a href="{aurl}"><img class="av" src="{avatar}" alt="{nick}" /></a><p class="date"><a href="/say/{author}/{id}-{url}" class="permalink">Apskatīt ({resp} komentāri)</a> <a href="{aurl}">{nick}</a> pirms {time} teica:</p>{text}<div class="c"></div></div></li>
	<!-- END BLOCK : miniblog-list-node-->
</ul>
<div class="c"></div>
<p class="core-pager">{pager-next} {pager-numeric} {pager-prev}</p>
<!-- END BLOCK : miniblog-list-->
