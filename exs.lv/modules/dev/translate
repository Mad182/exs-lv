function form_end($value, $name = 'submit') {
	echo '<p class="input submit"><input class="button" type="submit" name="'.htmlspecialchars($name).'" value="'.htmlspecialchars($value).'" /></p>';
}

function form_field($name, $value = '', $title = '', $type = 'text', $class = '', $options = array()) {
	if(empty($title)) {
    $title = ucfirst(str_replace('_',' ',$name));
	}
	$type = htmlspecialchars(strtolower(strip_tags($type)));
	echo '<p class="input input-'.$type.' '.$class.'">';

	if($type == 'checkbox') {
		echo '<label><input type="checkbox" id="input-'.htmlspecialchars($name).'" name="'.htmlspecialchars($name).'" type="'.$type.'" value="'.htmlspecialchars($value).'"';
		if(!empty($value)) {echo ' checked="checked"';}
		echo' />'.$title.'</label>';

	} else {
		echo '<label for="input-'.htmlspecialchars($name).'">'.$title.':</label><br />';
		if($type == 'text' || $type == 'hidden' || $type == 'password') {
			echo '<input class="text" id="input-'.htmlspecialchars($name).'" name="'.htmlspecialchars($name).'" type="'.$type.'" value="';
			if(!empty($value)) { echo htmlspecialchars($value); }
			echo '" />';
		} elseif($type == 'textarea') {
			echo '<textarea id="input-'.htmlspecialchars($name).'" rows="4" cols="20" name="'.htmlspecialchars($name).'">';
			if(!empty($value)) { echo htmlspecialchars($value); }
			echo '</textarea>';
		} elseif($type == 'submit') {
			form_end($title);
		} elseif($type == 'select') {
			echo '<select name="'.htmlspecialchars($name).'" id="input-'.htmlspecialchars($name).'">';
			if(!empty($options)) {
				foreach($options as $key => $val) {
					echo '<option value="'.htmlspecialchars($key).'"';
					if($value == $key) {echo ' selected="selected"';}
					echo '>'.htmlspecialchars($val).'</option>';
				}
			} else {
				echo '<option value="'.htmlspecialchars($value).'">'.htmlspecialchars($value).'</option>';
			}
			echo '</select>';
		} else {
			echo '<span class="error">Wrong input type!</span>';
		}
	}
	echo '</p>';
}

