function add_mod_recursive($catid, $usrid) {
	global $db;
	$usr = get_user($usrid);
	$cat = get_cat($catid);
	if ($cat && $usr) {
		if (!$db->get_var("SELECT count(*) FROM `cat_moderators` WHERE `category_id` = '$cat->id' AND `user_id` = '$usr->id'")) {
			$db->query("INSERT INTO `cat_moderators` (`category_id`,`user_id`) VALUES ('$cat->id', '$usr->id')");
			echo "INSERT INTO `cat_moderators` (`category_id`,`user_id`) VALUES ('$cat->id', '$usr->id')<br />";
		}
		$subcats = $db->get_results("SELECT `id` FROM `cat` WHERE `parent` = '$cat->id'");
		if ($subcats) {
			foreach ($subcats as $subcat) {
				add_mod_recursive($subcat->id, $usr->id);
			}
		}
	}
}

