<h1 style="margin-top:-20px">Jaunākās RuneScape ziņas</h1>
<!-- START BLOCK : rs-articles -->
    <!-- START BLOCK : rs-article -->
    <div class="rs-article">
        <!-- START BLOCK : article-image -->
        <div class="rs-article-logo">
            <img src="{sm_avatar}">
        </div>
        <!-- END BLOCK : article-image -->
        <p class="rs-article-title"><a href="/read/{strid}">{title}</a></p>
        <div class="rs-article-text">
            {text}
        </div>
        <ul class="rs-article-info">
            <li class="date">{date}</li>
            <li class="comments">
                <a href="{node-url}#comments">{posts}x</a>
            </li>
            <li class="profile user-level-{level}">
                <a href="{aurl}">{user_nick}</a>
            </li>
            <li style="float:right"><a style="float:right" href="/read/{strid}">Lasīt vairāk...</a></li>
        </ul>
    </div>    
    <!-- END BLOCK : rs-article -->
<p class="pagelist">{pages}</p>
<!-- END BLOCK : rs-articles -->
